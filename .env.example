# Copy to .env and adjust as needed. Defaults match docker-compose.yml.
# .env is gitignored; commit only this template.

# Postgres container (read by docker-compose.yml)
POSTGRES_DB=bookhaven
POSTGRES_USER=bookhaven
POSTGRES_PASSWORD=bookhaven
POSTGRES_PORT=5432

# App-side connection string (read by the pg client in src/lib/db.ts)
DATABASE_URL=postgresql://bookhaven:bookhaven@localhost:5432/bookhaven
